# Orion Labs Climate Risk API — Environment Variables
# Copy this file to .env and fill in your values

# Authentication
API_KEY=orion-dev-key-2024

# Postgres (Render example)
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./orion.db

# Comma-separated frontend origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Metadata
MODEL_VERSION=orion-climate-v2.1
CONFIDENCE_SCORE=0.942
DEFAULT_DATA_SOURCE=open-meteo
APP_ENV=development

# Optional: NASA FIRMS wildfire hotspot feed
FIRMS_MAP_KEY=
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_DAY_RANGE=2
WILDFIRE_RADIUS_KM=75

# Scheduler security (required for /internal/pipeline/*)
CRON_SECRET=change-me
DAILY_BACKFILL_DAYS=2

# Optional: Copernicus CDS / ERA5 credentials
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=
CDS_DATASET=reanalysis-era5-single-levels
CDS_VARIABLE=2m_temperature
CDS_AREA_NORTH=42.5
CDS_AREA_WEST=25.0
CDS_AREA_SOUTH=35.5
CDS_AREA_EAST=45.0
ERA5_GCS_BUCKET=
ERA5_MAX_CONCURRENT_JOBS=1
